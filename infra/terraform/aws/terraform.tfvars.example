project_name      = "MoraAI"
aws_region        = "us-east-1"
instance_type     = "t3.micro"
key_name          = "your-aws-keypair-name"
allowed_ssh_cidr  = "YOUR_PUBLIC_IP/32"
vpc_cidr          = "10.20.0.0/16"
public_subnet_cidrs = ["10.20.1.0/24", "10.20.2.0/24"]

enable_ecr                  = true
ecr_repository_name         = "moraai"
enable_eks                  = false
eks_cluster_name            = "moraai-eks"
eks_node_instance_types     = ["t3.micro"]
eks_node_desired_size       = 2
eks_node_min_size           = 1
eks_node_max_size           = 3
enable_bedrock              = true
enable_cloudwatch_log_group = true
cloudwatch_log_retention_days = 14

# Lambda + API Gateway for Bedrock RCA
enable_lambda        = true
lambda_function_name = "moraai-bedrock-rca"
lambda_zip_path      = "../../../infra/lambda/rca/moraai-bedrock-rca.zip"
bedrock_model_id     = "amazon.nova-lite-v1:0"
